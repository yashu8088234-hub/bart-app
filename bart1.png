es":null,"like_count":241,"like_and_view_counts_disabled":false,"boosted_status":null,"boost_unavailable_identifier":null,"boost_unavailable_reason":null,"comment_count":4,"comments_disabled":null,"view_count":null,"id":"3822241761360258682_16947381400"},{"pk":"3818717911293029719","accessibility_caption":null,"caption":{"pk":"18171057829388682","text":"\u062f\u0648\u0648\u064a\u0632\u2026 \u0648\u0627\u0641\u0644 \u0644\u064a\u064a\u062c \u0627\u0644\u0628\u0644\u062c\u064a\u0643\u064a \u0627\u0644\u0623\u0635\u064a\u0644 \ud83c\udde7\ud83c\uddea\n\u0645\u0643\u0648\u0646\u0627\u062a \u0641\u0627\u062e\u0631\u0629\u060c \u0633\u0643\u0631 \u0644\u0624\u0644\u0624\u064a \u064a\u062a\u0643\u0631\u0645\u0644 \u0648\u064a\u0639\u0637\u064a \u0642\u0631\u0645\u0634\u0629 \u0645\u0645\u064a\u0632\u0629\u060c \u0648\u0637\u0639\u0645 \u064a\u0639\u0644\u0642 \u0645\u0646 \u0623\u0648\u0644 \u0644\u0642\u0645\u0629.\n\u0625\u0630\u0627 \u062a\u062d\u0628 \u0627\u0644\u062a\u062c\u0627\u0631\u0628 \u0627\u0644\u0645\u062e\u062a\u0644\u0641\u0629 \u0641\u0639\u0644\u064b\u0627\u2026 \u0644\u0627\u0632\u0645 \u062a\u062c\u0631\u0651\u0628\u0647.\n\n\ud83d\udd17 \u0627\u0644\u0637\u0644\u0628 \u0639\u0628\u0631 \u062c\u0645\u064a\u0639 \u062a\u0637\u0628\u064a\u0642\u0627\u062a \u0627\u0644\u062a\u0648\u0635\u064a\u0644\u060c \u0627\u0648 \u0627\u0644\u0627\u0633\u062a\u0644\u0627\u0645 \u0645\u0646 \u0627\u0644\u0641\u0631\u0639\n\ud83d\udccd \u062c\u062f\u0629 \u2013 \u062d\u064a \u0627\u0644\u0633\u0644\u0627\u0645\u0629\n.\n.\nDoughy\u2019s\u2026 Authentic Belgian Li\u00e8ge Waffle \ud83c\udde7\ud83c\uddea\nPremium ingredients, pearl sugar that caramelizes for a signature crunch, and a flavor that sticks with you from the very first bite.\nIf you truly love unique experiences\u2026 this one\u2019s a must-try.\n\n\ud83d\udd17 Order via all delivery apps, or pick up from the branch"},"audience":null,"carousel_media_count":8,"display_uri":"https:\/\/instagram.fjed5-1.fna.fbcd